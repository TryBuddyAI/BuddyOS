{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "BUDDY app capabilities — single window can talk to the Rust core for hotkey, chat streaming, and key management.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "opener:default",
    "global-shortcut:default",
    "store:default",
    "autostart:default",
    "clipboard-manager:default",
    "notification:default",
    "shell:default",
    "shell:allow-open",
    "window-state:default"
  ]
}
